{
  "info": {
    "name": "PROPIG - Employee Management API",
    "description": "Complete RBAC Testing Collection with Fixed UUIDs for CRUD Operations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login - SUPER",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"super_token\", jsonData.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"super\",\n  \"password\": \"super123\"\n}"
            },
            "url": { "raw": "http://localhost:8000/users/login", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["users", "login"] }
          }
        },
        {
          "name": "Login - MANAGER (Financeiro)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"manager_token\", jsonData.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"gerente_financeiro\",\n  \"password\": \"manager123\"\n}"
            },
            "url": { "raw": "http://localhost:8000/users/login", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["users", "login"] }
          }
        },
        {
          "name": "Login - EMPLOYEE (TI)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"employee_token\", jsonData.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"funcionario_ti\",\n  \"password\": \"employee123\"\n}"
            },
            "url": { "raw": "http://localhost:8000/users/login", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["users", "login"] }
          }
        }
      ]
    },
